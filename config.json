{
"global_settings": {
    "timeout": 10,
    "user_agent": "Mozilla/5.0 (Multilingual NLP Dataset Crawler)",
    "max_workers": 15
  },
  "languages": {
    "gujarati": {
      "enabled": true,
      "lang_code": "gu",
      "regex_pattern": "[\\u0A80-\\u0AFF\\s.,!?;:'\"()\\[\\]\\-—\\u0964\\u0965]+",
      "base_urls": ["https://gujarati.indianexpress.com/sports","https://www.loksattanews.co.in/category/international","https://gujarati.abplive.com/news/business","https://chitralekha.com/category/features/", "https://www.kutchmitradaily.com/", "https://www.divyabhaskar.co.in/","https://www.gujaratsamachar.com/", "https://www.bbc.com/gujarati"],
      "max_pages": 50,
      "output_file": "data/gujarati_corpus.jsonl"
    },
    "hindi": {
      "enabled": false,
      "lang_code": "hi",
      "regex_pattern": "[\\u0900-\\u097F\\s.,!?;:'\"()\\[\\]\\-—\\u0964\\u0965]+",
      "base_urls": ["https://hi.wikipedia.org/wiki/%E0%A4%AA%E0%A5%8D%E0%A4%B0%E0%A4%BE%E0%A4%95%E0%A5%83%E0%A4%A4%E0%A4%BF%E0%A4%95_%E0%A4%AD%E0%A4%BE%E0%A4%B7%E0%A4%BE_%E0%A4%B8%E0%A4%82%E0%A4%B8%E0%A4%BE%E0%A4%A7%E0%A4%A8"],
      "max_pages": 100,
      "output_file": "data/hindi_corpus.jsonl"
    },
    "english": {
      "enabled": false,
      "lang_code": "en",
      "regex_pattern": "[a-zA-Z0-9\\s.,!?;:'\"()\\[\\]\\-—]+",
      "base_urls": ["https://timesofindia.indiatimes.com/"],
      "max_pages": 10,
      "output_file": "data/english_corpus.jsonl"
    }
  }
}