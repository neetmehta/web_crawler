{
"global_settings": {
    "timeout": 10,
    "user_agent": "Mozilla/5.0 (Multilingual NLP Dataset Crawler)",
    "max_workers": 15
  },
  "languages": {
    "gujarati": {
      "enabled": true,
      "lang_code": "gu",
      "regex_pattern": "[\\u0A80-\\u0AFF\\s.,!?;:'\"()\\[\\]\\-—\\u0964\\u0965]+",
      "base_urls": ["https://gujarati.webdunia.com/"],
      "max_pages": 50,
      "output_file": "data/gujarati_corpus.jsonl"
    },
    "hindi": {
      "enabled": false,
      "lang_code": "hi",
      "regex_pattern": "[\\u0900-\\u097F\\s.,!?;:'\"()\\[\\]\\-—\\u0964\\u0965]+",
      "base_urls": ["https://hi.wikipedia.org/wiki/%E0%A4%AA%E0%A5%8D%E0%A4%B0%E0%A4%BE%E0%A4%95%E0%A5%83%E0%A4%A4%E0%A4%BF%E0%A4%95_%E0%A4%AD%E0%A4%BE%E0%A4%B7%E0%A4%BE_%E0%A4%B8%E0%A4%82%E0%A4%B8%E0%A4%BE%E0%A4%A7%E0%A4%A8"],
      "max_pages": 100,
      "output_file": "data/hindi_corpus.jsonl"
    },
    "english": {
      "enabled": false,
      "lang_code": "en",
      "regex_pattern": "[a-zA-Z0-9\\s.,!?;:'\"()\\[\\]\\-—]+",
      "base_urls": ["https://economictimes.indiatimes.com/news/newsblogs/", "https://timesofindia.indiatimes.com/", "https://www.hindustantimes.com/", "https://www.ndtv.com/", "https://www.indiatoday.in/", "https://www.englishnews.com/", "https://www.bbc.com/news", "https://www.cnn.com/", "https://www.nytimes.com/", "https://www.theguardian.com/international", "https://www.reuters.com/", "https://www.aljazeera.com/"],
      "max_pages": 10,
      "output_file": "data/english_corpus.jsonl"
    }
  }
}